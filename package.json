{
  "name": "cdk-typescript-template",
  "version": "1.0.0",
  "bin": {
    "cdk-typescript-template": "cdk/bin/app.ts"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "test": "npm run test:unit && npm run test:cdk --runInBand",
    "test:unit": "jest --config jest.unit.config.ts",
    "test:cdk": "jest --coverage --config jest.cdk.config.ts --runInBand",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prettier:fix": "prettier './**/*.{.js,ts}' --check --write",
    "prettier:check": "prettier './**/*.{.js,ts}' --check"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "aws-cdk": "2.1100.1",
    "aws-sdk-client-mock": "^4.1.0",
    "babel-jest": "^30.2.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.962.0",
    "@aws-sdk/client-dynamodb": "^3.957.0",
"@aws-sdk/lib-dynamodb": "^3.957.0",
    "@types/aws-lambda": "^8.10.159",
    "@types/uuid": "^10.0.0",
    "aws-cdk-lib": "^2.232.1",
    "aws-lambda": "^1.0.7",
    "aws-sdk": "^2.1693.0",
    "constructs": "^10.0.0",
    "husky": "^9.1.7",
    "joi": "^18.0.2",
    "prettier": "^3.6.2",
    "uuid": "^10.0.0"
  }
}
